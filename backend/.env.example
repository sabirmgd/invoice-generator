NODE_ENV=development
PORT=8100

DB_HOST=localhost
DB_PORT=8001
DB_USERNAME=invoice_user
DB_PASSWORD=your_db_password
DB_DATABASE=invoice_generator
DB_SYNC=true
DB_LOGGING=true

# Cloud SQL (production — leave empty for local dev)
DB_SOCKET_PATH=
CLOUD_SQL_CONNECTION_NAME=

PDF_OUTPUT_DIR=./generated/invoices

# Firebase Auth (optional — leave empty to disable)
FIREBASE_PROJECT_ID=
FIREBASE_CLIENT_EMAIL=
FIREBASE_PRIVATE_KEY=

# Encryption master key (32-byte hex string)
# Generate with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
ENCRYPTION_MASTER_KEY=

# reCAPTCHA Enterprise (optional — skipped if not set)
RECAPTCHA_SITE_KEY=
RECAPTCHA_PROJECT_ID=
RECAPTCHA_SCORE_THRESHOLD=0.5

# Server-side Anthropic key (optional — enables no-BYOK mode)
ANTHROPIC_API_KEY=

# SendGrid (optional — email sending disabled if not set)
SENDGRID_API_KEY=
SENDGRID_FROM_EMAIL=invoices@yourdomain.com

# Stripe (optional — payments disabled if not set)
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
STRIPE_SUCCESS_URL=http://localhost:3000/portal/{token}?payment=success
STRIPE_CANCEL_URL=http://localhost:3000/portal/{token}?payment=cancelled
